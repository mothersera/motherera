# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/motherera

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here # Generate with: openssl rand -base64 32

# OAuth Providers
# Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple (https://developer.apple.com/account/resources/identifiers/list/serviceId)
APPLE_ID=
APPLE_SECRET=

# Razorpay Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Shopify Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Firebase Client SDK (Get these from Project Settings -> General -> Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (Get these from Project Settings -> Service accounts -> Generate new private key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
