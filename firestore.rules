rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    // Since we are using Anonymous Auth and MongoDB IDs, we cannot verify 
    // ownership strictly against request.auth.uid.
    // We rely on the client to behave correctly with the MongoDB IDs.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection (Legacy/Unused but kept for reference)
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }
    
    // Blocked collection
    match /blocked/{blockId} {
      allow read, write: if isAuthenticated();
    }

    // Chats collection
    match /chats/{chatId} {
      allow read, write: if isAuthenticated();

      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow create: if isAuthenticated();
    }
  }
}
